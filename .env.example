# Copy this file to .env and fill in real values.
# The project loads .env automatically on Windows and macOS; no shell export is needed.

# DeepSeek API key used by all LLM steps.
# DEEPSEEK_API_KEY="your-deepseek-api-key"

# Public-account article API key from down.mptext.top.
# WECHAT_PUBLIC_API_KEY="your-public-api-key"

# Optional: official WeChat account AppID for the reserved direct draft API.
# WECHAT_MP_APPID=""

# Optional: official WeChat account AppSecret for the reserved direct draft API.
# WECHAT_MP_APPSECRET=""

# Selenium browser: chrome, edge, or safari.
# WANYOU_SELENIUM_BROWSER="chrome"

# Optional: compatible LLM endpoint and model overrides.
# LLM_PROVIDER="deepseek"
# LLM_MODEL="deepseek-v4-flash"
# LLM_BASE_URL=""
# LLM_API_KEY_ENV=""

# Optional: set to 0 if real OS environment variables should override .env values.
# WANYOU_DOTENV_OVERRIDE="1"
